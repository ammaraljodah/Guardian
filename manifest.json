{
  "manifest_version": 3,
  "name": "Guardian - Parental Site Blocker",
  "version": "1.0.0",
  "description": "PIN-protected parental control that blocks sites and whole categories (social, games, adult, proxies). Works behind VPNs and proxies.",
  "permissions": ["tabs", "storage", "webNavigation"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Guardian"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ]
}
